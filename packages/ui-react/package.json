{
  "name": "@jhonatankennedy/ui-react",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles/reset": "./dist/styles/base.css"
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles/reset": "./src/styles.ts"
  },
  "sideEffects": [
    "./dist/styles/base.css",
    "./src/styles.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm build:styles",
    "build:styles": "mkdir -p dist/styles && cp ../ui-core/dist/styles/reset.css dist/styles/base.css",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@jhonatankennedy/ui-core": "workspace:*",
    "lucide-react": "0.487.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
