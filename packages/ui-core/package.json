{
  "name": "@jhonatankennedy/ui-core",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./styles/reset": "./dist/styles/reset.css"
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles/reset": "./src/reset.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && pnpm build:styles",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:styles": "sass src/styles/reset.scss dist/styles/reset.css --no-source-map"
  },
  "dependencies": {
    "lit": "^3.3.3",
    "lucide-static": "^1.23.0"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.10",
    "playwright": "^1.61.1",
    "sass": "^1.101.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
